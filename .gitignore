# ===================================================================
# 競技プログラミング共通・入出力ファイル
# ===================================================================
# ローカルテスト用の入出力テキストファイル（必要に応じて調整）
*.txt
*.in
*.out
!README.md

# online-judge-tools (oj) などのテスト用ディレクトリ
test/
.online-judge-tools/

# ===================================================================
# C++
# ===================================================================
# コンパイル済みオブジェクトファイル・バイナリ
*.o
*.obj
*.out
*.exe
*.gch

# Mac用のデバッグ情報フォルダ
*.dSYM/

# ===================================================================
# Rust
# ===================================================================
# ビルド生成物（これがないとリポジトリが激重になります）
/target/

# ===================================================================
# Python
# ===================================================================
# キャッシュ、バイトコード
__pycache__/
*.pyc
*.pyo
*.pyd

# 仮想環境（使う場合）
.venv/
venv/
env/

# ===================================================================
# Golang
# ===================================================================
# テストやプロファイリングの生成物ß
*.prof

# ===================================================================
# エディタ・OS固有の一時ファイル
# ===================================================================
.idea/
.DS_Store
Thumbs.db
